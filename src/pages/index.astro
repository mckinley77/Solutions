---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const notes = (await getCollection('technical-notes'))
	.filter((note) => !note.data.draft)
	.sort((a, b) => b.data.number - a.data.number);

const latestNote = (await getCollection('technical-notes')).sort(
	(a, b) => b.data.number - a.data.number
)[0];
---

<BaseLayout
	title="Home"
	description="The Sustainable Golf Course Project - practical drainage and sustainability guidance for golf courses managing wet winters and short playing seasons, led by Maurice McKinley BSc CEng MICE."
>
	<section class="hero">
		<div class="hero__banner">
			<img
				class="hero__banner-image"
				src="/images/hero.jpg"
				alt="A golf green beside a pond, with a wooden bridge, reeds, and mature trees under a clear evening sky"
			/>
		</div>
		<div class="container hero__content">
			<h1>Drier courses, longer seasons, lower costs.</h1>
			<div class="hero__panel">
				<p class="lede">
					Running a golf course sustainably means protecting the environment, conserving
					water, managing trees and habitats, reducing emissions, keeping proper records
					instead of starting fresh each year, and avoiding the expense of solving the same
					problem twice.
				</p>
				<p class="lede">
					Ireland's wetter winters have made all of it harder, with shorter playing seasons
					and rising costs. This project takes a practical, low-cost approach across the
					board, from drainage engineering to the efficient practices that keep a course
					healthy everywhere else, so clubs can stay open longer, spend less, and do it all
					without costing the earth.
				</p>
			</div>
		</div>
	</section>

	<section class="section">
		<div class="container">
			<span class="eyebrow">The aim of this project</span>
			<p class="lede">
				This project shares practical, low-cost experience on the problems golf clubs face in
				the current climate: drainage failures, winter damage, water shortages in summer, tree
				management, and how new technology can genuinely help.
			</p>
			<p class="lede">
				I also hope it helps clubs develop effective practices and longer-term plans rather than
				struggling with the same issues year after year on tight budgets, and that it sparks
				conversation, interest, and observations from others in the golf world that can be shared
				for everyone's benefit.
			</p>
			<div class="grid grid--3" style="margin-top:2.5rem;">
				<div class="card">
					<h3>Drainage</h3>
					<p>
						Low-cost, drainage improvements to get greens, tees, and fairways playable earlier
						in spring and later into the autumn, engineered and planned, not guesswork.
					</p>
					<a href="/drainage/">Read more →</a>
				</div>
				<div class="card">
					<h3>Sustainability</h3>
					<p>
						The sustainability objectives here are practical: reducing fuel use and emissions,
						protecting trees and habitats, and making better use of resources, and embracing
						technology like robotic mowing to work smarter and reduce our environmental
						footprint.
					</p>
					<a href="/sustainability/">Read more →</a>
				</div>
				<div class="card">
					<h3>Technical Notes</h3>
					<p>
						Practical notes on drainage, machinery, and the problems clubs deal with, drawn from
						extensive contract and drainage design experience and years as a committee member
						and convenor.
					</p>
					<a href="/technical-notes/">Browse notes →</a>
				</div>
			</div>
		</div>
	</section>

	{latestNote && (
		<section class="section section--alt">
			<div class="container">
				<span class="eyebrow">Latest Technical Note</span>
				<div class="card note-card" style="max-width:40rem;">
					{latestNote.data.draft && <span class="badge-draft">Draft - coming soon</span>}
					<p class="note-card__meta">Technical Note {latestNote.data.number}</p>
					<h3><a href={`/technical-notes/${latestNote.id}/`}>{latestNote.data.title}</a></h3>
					<p>{latestNote.data.summary}</p>
					<a href={`/technical-notes/${latestNote.id}/`}>Read the note →</a>
				</div>
			</div>
		</section>
	)}

	<section class="section">
		<div class="container">
			<div class="card" style="display:flex; flex-wrap:wrap; gap:1.5rem; align-items:center; justify-content:space-between;">
				<div>
					<h2 style="margin-top:0;">Free introductory consultation</h2>
					<p style="margin-bottom:0; max-width:34rem;">
						A half-day, no-obligation consultation to look at your drainage and sustainability
						priorities and where the quickest wins are.
					</p>
				</div>
				<a class="btn btn--primary" href="/contact/">Get in touch</a>
			</div>
		</div>
	</section>
</BaseLayout>

<style>
	.section {
		padding: 2.25rem 0;
	}
</style>
