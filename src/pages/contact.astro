---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
	title="Contact"
	description="Get in touch with Maurice McKinley BSc CEng MICE about drainage and sustainability projects for your golf course."
>
	<section class="section section--tight hero">
		<div class="container">
			<span class="eyebrow">Contact</span>
			<h1>Get in touch</h1>
			<p class="lede">
				Enquiries usually start with a free, half-day introductory consultation, no obligation,
				to walk the course and identify priorities.
			</p>
		</div>
	</section>

	<section class="section">
		<div class="container grid grid--2">
			<div class="card">
				<h3>Maurice McKinley</h3>
				<p style="margin-bottom:1.5rem;">BSc CEng MICE - Civil Engineer &amp; Drainage Advisor</p>
				<dl class="contact-list">
					<div>
						<dt>Email</dt>
						<dd><a href="mailto:mckinley77@gmail.com">mckinley77@gmail.com</a></dd>
					</div>
					<div>
						<dt>Phone</dt>
						<dd><a href="tel:07544096463">07544096463</a></dd>
					</div>
				</dl>
			</div>
			<div class="card">
				<h3>Free consultation</h3>
				<p>
					A half-day, no-obligation visit to look at drainage and sustainability priorities for
					your course, and where the fastest wins are.
				</p>
				<p style="margin-bottom:0;">
					Email or call to arrange a date, or mention which course/club you're enquiring for.
				</p>
			</div>
		</div>
	</section>
</BaseLayout>
