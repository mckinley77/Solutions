---
import BaseLayout from '../layouts/BaseLayout.astro';

const photos = [
	{ src: '/images/gallery/17th-fairway-survey.jpg', caption: '17th Fairway Survey' },
	{ src: '/images/gallery/8th-fairway-survey.png', caption: '8th Fairway Survey' },
	{ src: '/images/gallery/8th-future-drainage.png', caption: '8th Future Drainage' },
	{ src: '/images/gallery/8th-survey2.png', caption: '8th Survey 2' },
	{ src: '/images/gallery/banks-stabilised.jpg', caption: 'Banks Stabilised' },
	{ src: '/images/gallery/bank-stabilisation.jpg', caption: 'Bank Stabilisation' },
	{ src: '/images/gallery/best-of-both-worlds-3.png', caption: 'Best of Both Worlds' },
	{ src: '/images/gallery/between-17th-and-18th.jpg', caption: 'Between 17th and 18th' },
	{ src: '/images/gallery/causeway-6.jpg', caption: 'Causeway 6' },
	{ src: '/images/gallery/course-plan.jpg', caption: 'Course Plan' },
	{ src: '/images/gallery/crib-wall.jpg', caption: 'Crib Wall' },
	{ src: '/images/gallery/drain-design-example.jpg', caption: 'Drain Design Example' },
	{ src: '/images/gallery/drains-by-excavator.png', caption: 'Drains by Excavator' },
	{ src: '/images/gallery/eighth-cs.jpg', caption: '8th Cross-Section' },
	{ src: '/images/gallery/example-b.jpg', caption: 'Design Example' },
	{ src: '/images/gallery/example-contours.jpg', caption: 'Example Contours' },
	{ src: '/images/gallery/gabion-solution.jpg', caption: 'Gabion Solution' },
	{ src: '/images/gallery/golpa.jpg', caption: 'Golpa' },
	{ src: '/images/gallery/gravel-drain.jpg', caption: 'Gravel Drain' },
	{ src: '/images/gallery/gravel-drains.jpg', caption: 'Gravel Drains' },
	{ src: '/images/gallery/leaves-in-rough.jpg', caption: 'Leaves in Rough' },
	{ src: '/images/gallery/moneyreagh-diversion.jpg', caption: 'Moneyreagh Diversion' },
	{ src: '/images/gallery/practice-area.png', caption: 'Practice Area' },
	{ src: '/images/gallery/rainfall-trends.jpg', caption: 'Rainfall Trends' },
	{ src: '/images/gallery/range-bays.png', caption: 'Range Bays' },
	{ src: '/images/gallery/refreshed-drain.jpg', caption: 'Refreshed Drain' },
	{ src: '/images/gallery/sand-washout.jpg', caption: 'Sand Washout' },
	{ src: '/images/gallery/sleeper-wall.png', caption: 'Sleeper Wall' },
	{ src: '/images/gallery/spring-again.jpg', caption: 'Spring Again' },
	{ src: '/images/gallery/structures-2.jpg', caption: 'Structures 2' },
	{ src: '/images/gallery/temp-green-much-too-small.jpg', caption: 'Temp Green - Much too Small' },
	{ src: '/images/gallery/trencher.jpg', caption: 'Trencher' },
];
---

<BaseLayout
	title="Gallery"
	description="Photos of drainage, survey, and sustainability projects on golf courses."
>
	<section class="section section--tight hero">
		<div class="container">
			<span class="eyebrow">Gallery</span>
			<h1>Project photos</h1>
			<p class="lede">Photos from drainage, survey, and structural projects on golf courses.</p>
		</div>
	</section>

	<section class="section">
		<div class="container">
			<div class="grid grid--3">
				{photos.map(({ src, caption }) => (
					<div>
						<img src={src} alt={caption} style="width:100%; height:auto; border-radius:8px;" />
						<p style="font-size:0.9rem; margin-top:0.5rem;">{caption}</p>
					</div>
				))}
			</div>
		</div>
	</section>
</BaseLayout>
