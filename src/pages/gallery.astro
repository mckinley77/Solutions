---
import BaseLayout from '../layouts/BaseLayout.astro';

const photos = [
	{ src: '/images/gallery/drainage-installation.jpg', caption: 'Drainage installation — new pipe runs across the fairway' },
	{ src: '/images/gallery/tee-before.jpg', caption: 'Before: worn tee surrounds' },
	{ src: '/images/gallery/tee-after.jpg', caption: 'After: tee surrounds restored' },
	{ src: '/images/gallery/completed-outfall.jpg', caption: 'Completed outfall coping with high flow' },
	{ src: '/images/gallery/retaining-wall.jpg', caption: 'Retaining wall — bank stabilisation' },
	{ src: '/images/gallery/course-survey.jpg', caption: 'Course survey — Shandon Park GC, 17th fairway' },
	{ src: '/images/gallery/course-context-1.jpg', caption: 'Course context' },
	{ src: '/images/gallery/course-context-2.jpg', caption: 'Course context' },
	{ src: '/images/technical-notes/robotic-mower-on-course.jpg', caption: 'Robotic mower on course' },
];
---

<BaseLayout
	title="Gallery"
	description="Photos of drainage, survey, and sustainability projects on golf courses."
>
	<section class="section section--tight hero">
		<div class="container">
			<span class="eyebrow">Gallery</span>
			<h1>Project photos</h1>
			<p class="lede">Photos from drainage, survey, and structural projects on golf courses.</p>
		</div>
	</section>

	<section class="section">
		<div class="container">
			<div class="grid grid--3">
				{photos.map(({ src, caption }) => (
					<div>
						<img src={src} alt={caption} style="width:100%; height:auto; border-radius:8px;" />
						<p style="font-size:0.9rem; margin-top:0.5rem;">{caption}</p>
					</div>
				))}
			</div>
		</div>
	</section>
</BaseLayout>
